{
  "name": "gamified-work-tracker",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest --watchAll=false",
    "e2e:server": "EXPO_NO_DOTENV=1 EXPO_PUBLIC_FORCE_DEMO_MODE=1 EXPO_PUBLIC_SUPABASE_URL= EXPO_PUBLIC_SUPABASE_ANON_KEY= EXPO_PUBLIC_APP_ENV=development expo export --clear --platform web --output-dir dist-e2e && serve -s dist-e2e -l 8081",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "auth:redirects": "node scripts/print-auth-redirects.mjs",
    "ios:demo": "EXPO_NO_DOTENV=1 EXPO_PUBLIC_FORCE_DEMO_MODE=1 EXPO_PUBLIC_SUPABASE_URL= EXPO_PUBLIC_SUPABASE_ANON_KEY= EXPO_PUBLIC_APP_ENV=development expo run:ios",
    "ios:demo:iphone16": "EXPO_NO_DOTENV=1 EXPO_PUBLIC_FORCE_DEMO_MODE=1 EXPO_PUBLIC_SUPABASE_URL= EXPO_PUBLIC_SUPABASE_ANON_KEY= EXPO_PUBLIC_APP_ENV=development expo run:ios --device \"iPhone 16\"",
    "test:maestro:ios": "PATH=\"$PATH:$HOME/.maestro/bin\" MAESTRO_CLI_NO_ANALYTICS=1 MAESTRO_CLI_ANALYSIS_NOTIFICATION_DISABLED=true maestro test -e APP_ID=com.applyloop.app .maestro",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop --no-backup",
    "db:reset": "supabase db reset --no-seed",
    "db:lint": "supabase db lint --fail-on error",
    "test:db": "supabase db reset --no-seed && supabase db lint --fail-on error && supabase test db",
    "db:types": "supabase gen types typescript --local | perl -0pe 's/\\n+\\z/\\n/' > src/types/database.ts",
    "db:types:check": "supabase gen types typescript --local | perl -0pe 's/\\n+\\z/\\n/' > /tmp/applyloop-database.ts && diff -u src/types/database.ts /tmp/applyloop-database.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.105.0",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^1.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "serve": "^14.2.6",
    "supabase": "2.98.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.(ts|tsx)"
    ]
  }
}
